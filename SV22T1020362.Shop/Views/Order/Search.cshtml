@using SV22T1020362.Models.Sales
@model PagedResult<OrderViewInfo>
@{
    Layout = null; // Partial view — không dùng layout
}

@if (!Model.DataItems.Any() && Model.RowCount == 0)
{
    <div class="text-center py-5 bg-white rounded border">
        <i class="bi bi-bag-x fs-1 text-muted"></i>
        <h5 class="mt-3 text-muted">Không tìm thấy đơn hàng nào</h5>
        <a href="~/Product" class="btn btn-primary mt-2">
            <i class="bi bi-grid me-1"></i>Bắt đầu mua sắm
        </a>
    </div>
}
else
{
    <div class="mb-2 text-muted small">
        Tìm thấy <strong>@Model.RowCount</strong> đơn hàng
    </div>

    <div class="bg-white border rounded overflow-hidden">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-primary">
                <tr>
                    <th style="width:80px">Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Ngày cập nhật</th>
                    <th style="width:70px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.DataItems)
                {
                    @* Lấy thời gian cập nhật mới nhất theo trạng thái *@
                    DateTime? lastUpdate = order.Status switch
                    {
                        OrderStatusEnum.Completed => order.FinishedTime,
                        OrderStatusEnum.Shipping => order.ShippedTime,
                        OrderStatusEnum.Accepted => order.AcceptTime,
                        OrderStatusEnum.Cancelled => order.FinishedTime,
                        OrderStatusEnum.Rejected => order.FinishedTime,
                        _ => null
                    };

                    @* Badge CSS class theo trạng thái *@
                    string badgeClass = order.Status switch
                    {
                        OrderStatusEnum.New => "order-status-new",
                        OrderStatusEnum.Accepted => "order-status-accepted",
                        OrderStatusEnum.Shipping => "order-status-shipping",
                        OrderStatusEnum.Completed => "order-status-completed",
                        OrderStatusEnum.Cancelled => "order-status-cancelled",
                        OrderStatusEnum.Rejected => "order-status-rejected",
                        _ => "bg-secondary text-white"
                    };

                    <tr>
                        <td class="fw-semibold">#@order.OrderID</td>
                        <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end fw-semibold text-primary">
                            @order.SumOfPrice.ToString("N0") đ
                        </td>
                        <td class="text-center">
                            <span class="badge @badgeClass">@order.Status.GetDescription()</span>
                        </td>
                        <td class="text-center text-muted small">
                            @(lastUpdate.HasValue? lastUpdate.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                        </td>
                        <td class="text-center">
                            <a href="~/Order/Detail/@order.OrderID"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Xem
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Phân trang AJAX *@
    @if (Model.PageCount > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsCurrent)
                    {
                        <li class="page-item active">
                            <span class="page-link">@p.Page</span>
                        </li>
                    }
                    else if (p.IsEllipsis)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;"
                               onclick="orderSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }
            </ul>
        </nav>
    }
}