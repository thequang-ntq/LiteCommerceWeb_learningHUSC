@model List<OrderViewInfo>
@{
    ViewBag.Title = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <h2 class="section-title">
        <i class="bi bi-clock-history me-2"></i>Lịch sử đơn hàng
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded border">
            <i class="bi bi-bag-x fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Bạn chưa có đơn hàng nào</h5>
            <a href="~/Product" class="btn btn-primary mt-2">
                <i class="bi bi-grid me-1"></i>Bắt đầu mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="bg-white border rounded overflow-hidden">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Ngày cập nhật</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <!-- Lấy thời gian cập nhật mới nhất -->
                        DateTime? lastUpdate = order.Status switch
                        {
                            OrderStatusEnum.Completed => order.FinishedTime,
                            OrderStatusEnum.Shipping => order.ShippedTime,
                            OrderStatusEnum.Accepted => order.AcceptTime,
                            OrderStatusEnum.Cancelled => order.FinishedTime,
                            OrderStatusEnum.Rejected => order.FinishedTime,
                            _ => null
                        };

                        // Badge class theo trạng thái
                        string badgeClass = order.Status switch
                        {
                            OrderStatusEnum.New => "order-status-new",
                            OrderStatusEnum.Accepted => "order-status-accepted",
                            OrderStatusEnum.Shipping => "order-status-shipping",
                            OrderStatusEnum.Completed => "order-status-completed",
                            OrderStatusEnum.Cancelled => "order-status-cancelled",
                            OrderStatusEnum.Rejected => "order-status-rejected",
                            _ => "bg-secondary text-white"
                        };
                        string badgeText = order.Status.GetDescription();

                        <tr>
                            <td class="fw-semibold">#@order.OrderID</td>
                            <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end fw-semibold text-primary">
                                @order.SumOfPrice.ToString("N0") đ
                            </td>
                            <td class="text-center">
                                <span class="badge @badgeClass">@badgeText</span>
                            </td>
                            <td class="text-center text-muted small">
                                @(lastUpdate.HasValue? lastUpdate.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                            </td>
                            <td class="text-center">
                                <a href="~/Order/Detail/@order.OrderID" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>Xem
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>