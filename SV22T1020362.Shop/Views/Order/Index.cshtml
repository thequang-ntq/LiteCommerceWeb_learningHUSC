@{
    ViewBag.Title = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <h2 class="section-title">
        <i class="bi bi-clock-history me-2"></i>Lịch sử đơn hàng
    </h2>

    <!-- Thanh tìm kiếm -->
    <form id="formSearch"
          method="get"
          action="~/Order/Search"
          data-target="searchResult"
          onsubmit="orderSearch(event, this, 1)">

        <input type="hidden" name="pageSize" value="10" />

        <div class="bg-white border rounded p-3 mb-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small fw-semibold">Tìm theo mã đơn / trạng thái / địa chỉ</label>
                    <input type="text"
                           name="searchValue"
                           class="form-control"
                           placeholder="Nhập mã đơn hàng, trạng thái hoặc địa chỉ..."
                           autofocus />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>Tìm kiếm
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- Kết quả tìm kiếm (load qua AJAX) -->
    <div id="searchResult">
        <div class="text-center py-4 text-muted">Đang tải đơn hàng...</div>
    </div>
</div>

@section Scripts {
    <script>
        /**
         * Gửi tìm kiếm đơn hàng qua AJAX
         * param {Event|null} event
         * param {HTMLFormElement} form
         * param {number} page - Số trang cần tải
         */
        function orderSearch(event, form, page) {
            if (event) event.preventDefault();
            if (!form) return;

            const url = form.action;
            const params = new URLSearchParams(new FormData(form));
            params.set('page', page || 1);

            const targetEl = document.getElementById('searchResult');
            if (targetEl) {
                targetEl.innerHTML = `
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-arrow-repeat"></i> Đang tải...
                    </div>`;
            }

            fetch(url + '?' + params.toString())
                .then(res => res.text())
                .then(html => {
                    if (targetEl) targetEl.innerHTML = html;
                })
                .catch(() => {
                    if (targetEl) {
                        targetEl.innerHTML = `<div class="text-danger p-3">Không tải được dữ liệu</div>`;
                    }
                });
        }

        // Tải trang đầu tiên khi DOM sẵn sàng
        document.addEventListener('DOMContentLoaded', function () {
            orderSearch(null, document.getElementById('formSearch'), 1);
        });
    </script>
}