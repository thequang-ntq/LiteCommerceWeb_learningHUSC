@model ProductSearchInput
@{
    ViewBag.Title = "Sản phẩm";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="container py-4">
    <div class="row g-4">

        <!-- ===== SIDEBAR DANH MỤC ===== -->
        <div class="col-lg-2 col-md-3">
            <div class="category-sidebar">
                <div class="sidebar-title">
                    <i class="bi bi-grid me-1"></i>Danh mục
                </div>
                <nav class="nav flex-column">
                    <a href="javascript:;"
                       class="nav-link @(Model.CategoryID == 0 ? "active" : "")"
                       onclick="filterByCategory(0)">
                        Tất cả sản phẩm
                    </a>
                    @foreach (var cat in categories)
                    {
                        <a href="javascript:;"
                           class="nav-link @(Model.CategoryID == cat.CategoryID ? "active" : "")"
                           onclick="filterByCategory(@cat.CategoryID)">
                            @cat.CategoryName
                        </a>
                    }
                </nav>
            </div>
        </div>

        <!-- ===== MAIN CONTENT ===== -->
        <div class="col-lg-10 col-md-9">

            <!-- Thanh lọc & tìm kiếm -->
            <form id="formSearch"
                  method="get"
                  action="~/Product/Search"
                  data-target="searchResult"
                  onsubmit="productSearch(event, this, 1)">

                <input type="hidden" asp-for="CategoryID" id="inputCategoryID" />
                <input type="hidden" asp-for="PageSize" />

                <div class="bg-white border rounded p-3 mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Tìm kiếm</label>
                            <input type="text" asp-for="SearchValue"
                                   class="form-control"
                                   placeholder="Tên sản phẩm..." autofocus />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Giá từ (đ)</label>
                            <input type="number" asp-for="MinPrice"
                                   id="inputMinPrice"
                                   class="form-control"
                                   placeholder="0" min="0" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Giá đến (đ)</label>
                            <input type="number" asp-for="MaxPrice"
                                   id="inputMaxPrice"
                                   class="form-control"
                                   placeholder="Không giới hạn" min="0" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-1"></i>Lọc
                            </button>
                        </div>
                    </div>
                </div>
            </form>

            <!-- Kết quả tìm kiếm (load qua AJAX) -->
            <div id="searchResult">
                <div class="text-center py-4 text-muted">Đang tải sản phẩm...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        /**
         * Gửi tìm kiếm sản phẩm qua AJAX.
         * param {Event|null} event
         * param {HTMLFormElement} form
         * param {number} page - Số trang cần tải
         */
        function productSearch(event, form, page) {
            if (event) event.preventDefault();
            if (!form) return;

            // Unformat MinPrice / MaxPrice nếu người dùng gõ tay có dấu phân cách
            const minEl = document.getElementById('inputMinPrice');
            const maxEl = document.getElementById('inputMaxPrice');
            if (minEl) minEl.value = (parseFloat(minEl.value.replace(/\./g, '').replace(',', '.')) || 0).toString();
            if (maxEl) maxEl.value = (parseFloat(maxEl.value.replace(/\./g, '').replace(',', '.')) || 0).toString();

            const url = form.action;
            const params = new URLSearchParams(new FormData(form));
            params.set('page', page || 1);

            const targetId = form.dataset.target;
            const targetEl = targetId ? document.getElementById(targetId) : null;

            if (targetEl) {
                targetEl.innerHTML = `
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-arrow-repeat"></i> Đang tải...
                    </div>`;
            }

            fetch(url + '?' + params.toString())
                .then(res => res.text())
                .then(html => {
                    if (targetEl) targetEl.innerHTML = html;
                    // Cập nhật active class sidebar theo categoryID hiện tại
                    updateSidebarActive(parseInt(document.getElementById('inputCategoryID').value) || 0);
                })
                .catch(() => {
                    if (targetEl) {
                        targetEl.innerHTML = `<div class="text-danger p-3">Không tải được dữ liệu</div>`;
                    }
                });
        }

        /**
         * Lọc theo danh mục — cập nhật hidden input rồi tìm kiếm lại.
         * Reset luôn các ô tìm kiếm khác để tránh giữ điều kiện cũ.
         * param {number} categoryID
         */
        function filterByCategory(categoryID) {
            document.getElementById('inputCategoryID').value = categoryID;
            // Reset các trường lọc khác khi chọn danh mục
            const form = document.getElementById('formSearch');
            if (form) {
                const searchValueEl = form.querySelector('input[name="SearchValue"]');
                if (searchValueEl) searchValueEl.value = '';
                const minEl = document.getElementById('inputMinPrice');
                const maxEl = document.getElementById('inputMaxPrice');
                if (minEl) minEl.value = 0;
                if (maxEl) maxEl.value = 0;
            }
            productSearch(null, document.getElementById('formSearch'), 1);
        }

        /**
         * Xóa toàn bộ bộ lọc và tìm lại — định nghĩa ở đây (Index.cshtml)
         * thay vì trong Search.cshtml để tránh lỗi "not defined" khi script
         * được inject qua innerHTML (AJAX) không chạy trong global scope.
         */
        function clearFilter() {
            const form = document.getElementById('formSearch');
            if (!form) return;
            // Reset tất cả input text / number trong form
            form.querySelectorAll('input[type="text"], input[type="number"]').forEach(el => el.value = '');
            // Reset categoryID về 0 (tất cả)
            document.getElementById('inputCategoryID').value = 0;
            productSearch(null, form, 1);
        }

        /**
         * Cập nhật trạng thái active của sidebar theo categoryID
         * param {number} categoryID
         */
        function updateSidebarActive(categoryID) {
            document.querySelectorAll('.category-sidebar .nav-link').forEach(function (el) {
                el.classList.remove('active');
                const match = el.getAttribute('onclick')?.match(/filterByCategory\((\d+)\)/);
                if (match && parseInt(match[1]) === categoryID) {
                    el.classList.add('active');
                }
            });
        }

        // Tải trang đầu tiên khi DOM sẵn sàng
        document.addEventListener('DOMContentLoaded', function () {
            productSearch(null, document.getElementById('formSearch'), @Model.Page);
        });
    </script>
}