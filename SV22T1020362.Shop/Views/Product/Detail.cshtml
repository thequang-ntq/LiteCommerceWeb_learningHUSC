@model Product
@{
    ViewBag.Title = Model.ProductName;
    var photos = ViewBag.Photos as List<ProductPhoto> ?? new List<ProductPhoto>();
    var attributes = ViewBag.Attributes as List<ProductAttribute> ?? new List<ProductAttribute>();
    var related = ViewBag.Related as List<Product> ?? new List<Product>();

    // Ảnh hiển thị: dùng Photo của Product nếu không có trong gallery
    string mainPhoto = photos.FirstOrDefault(p => !p.IsHidden)?.Photo
                    ?? Model.Photo
                    ?? "nophoto.png";
}

<div class="container py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="~/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="~/Product">Sản phẩm</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    <!-- Chi tiết sản phẩm -->
    <div class="bg-white rounded border p-4 mb-4">
        <div class="row g-4">

            <!-- Cột ảnh -->
            <div class="col-md-5">
                <img id="mainProductImage"
                     src="~/images/products/@mainPhoto"
                     alt="@Model.ProductName"
                     class="product-detail-img w-100 mb-3" />

                <!-- Thumbnails -->
                @if (photos.Any(p => !p.IsHidden))
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var photo in photos.Where(p => !p.IsHidden).Take(6))
                        {
                            <img src="~/images/products/@photo.Photo"
                                 alt="@photo.Description"
                                 class="thumb-img @(photo.Photo == mainPhoto ? "active" : "")"
                                 onclick="switchMainImage('/images/products/@photo.Photo', this)" />
                        }
                    </div>
                }
            </div>

            <!-- Cột thông tin -->
            <div class="col-md-7">
                <h1 class="h3 fw-bold mb-2">@Model.ProductName</h1>

                <div class="mb-3">
                    <span class="fs-2 fw-bold text-primary">@Model.Price.ToString("N0") đ</span>
                    <span class="text-muted small ms-2">/ @Model.Unit</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
                {
                    <p class="text-muted mb-3">@Model.ProductDescription</p>
                }

                <!-- Trạng thái -->
                <div class="mb-3">
                    @if (Model.IsSelling)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Còn hàng</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Hết hàng</span>
                    }
                </div>

                <!-- Số lượng và thêm giỏ -->
                @if (Model.IsSelling)
                {
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="input-group" style="width:130px;">
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    onclick="changeQuantity('qtyInput', -1)">
                                <i class="bi bi-dash"></i>
                            </button>
                            <input type="number" id="qtyInput"
                                   class="form-control text-center"
                                   value="1" min="1" max="999" />
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    onclick="changeQuantity('qtyInput', 1)">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                        <button class="btn btn-primary btn-lg"
                                onclick="addToCart(@Model.ProductID, parseInt(document.getElementById('qtyInput').value))">
                            <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                        </button>
                    </div>
                    <a href="javascript:;" class="btn btn-warning btn-lg"
                       onclick="buyNow(@Model.ProductID)">
                        <i class="bi bi-lightning-fill me-2"></i>Mua ngay
                    </a>
                }

                <!-- Thuộc tính sản phẩm -->
                @if (attributes.Any())
                {
                    <hr />
                    <h6 class="fw-bold mb-2">Thông số kỹ thuật</h6>
                    <table class="table table-sm table-bordered">
                        <tbody>
                            @foreach (var attr in attributes.OrderBy(a => a.DisplayOrder))
                            {
                                <tr>
                                    <td class="fw-semibold bg-light" style="width:40%">@attr.AttributeName</td>
                                    <td>@attr.AttributeValue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Sản phẩm liên quan -->
    @if (related.Any())
    {
        <h2 class="section-title">Sản phẩm liên quan</h2>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
            @foreach (var item in related)
            {
                <div class="col">
                    <div class="product-card">
                        <a href="~/Product/Detail/@item.ProductID" class="text-decoration-none">
                            <div class="card-img-wrap">
                                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     alt="@item.ProductName" loading="lazy" />
                            </div>
                        </a>
                        <div class="card-body">
                            <a href="~/Product/Detail/@item.ProductID" class="text-decoration-none">
                                <div class="product-name">@item.ProductName</div>
                            </a>
                            <div class="product-price mb-1">@item.Price.ToString("N0") đ</div>
                            <button class="btn-add-cart"
                                    onclick="addToCart(@item.ProductID, 1)">
                                <i class="bi bi-cart-plus me-1"></i>Thêm giỏ
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        /**
         * Mua ngay: thêm vào giỏ rồi chuyển sang trang checkout
         */
        function buyNow(productID) {
            const qty = parseInt(document.getElementById('qtyInput').value) || 1;
            const formData = new FormData();
            formData.append('productID', productID);
            formData.append('quantity',  qty);

            fetch('/Cart/AddToCart', { method: 'POST', body: formData })
                .then(r => r.json())
                .then(result => {
                    if (result.success)
                        window.location.href = '/Cart/Checkout';
                    else
                        showToast(result.message, 'error');
                })
                .catch(() => showToast('Có lỗi xảy ra', 'error'));
        }
    </script>
}