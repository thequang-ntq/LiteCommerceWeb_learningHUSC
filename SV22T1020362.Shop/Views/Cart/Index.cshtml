@model List<OrderDetailViewInfo>
@{
    ViewBag.Title = "Giỏ hàng";
    decimal total = Model.Sum(x => x.TotalPrice);
}

<div class="container py-4">
    <h2 class="section-title">
        <i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded border">
            <i class="bi bi-cart-x fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Giỏ hàng đang trống</h5>
            <a href="~/Product" class="btn btn-primary mt-2">
                <i class="bi bi-grid me-1"></i>Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Bảng giỏ hàng -->
            <div class="col-lg-8">
                <div class="bg-white border rounded overflow-hidden">
                    <table class="table cart-table mb-0">
                        <thead>
                            <tr>
                                <th style="width:80px">Ảnh</th>
                                <th>Sản phẩm</th>
                                <th style="width:70px" class="text-center">ĐVT</th>
                                <th style="width:140px" class="text-center">Số lượng</th>
                                <th style="width:120px" class="text-end">Đơn giá</th>
                                <th style="width:130px" class="text-end">Thành tiền</th>
                                <th style="width:50px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="align-middle">
                                        <a href="~/Product/Detail/@item.ProductID">
                                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                                 alt="@item.ProductName" class="cart-img" />
                                        </a>
                                    </td>
                                    <td class="align-middle">
                                        <a href="~/Product/Detail/@item.ProductID"
                                           class="text-decoration-none fw-semibold text-dark">
                                            @item.ProductName
                                        </a>
                                    </td>
                                    <td class="text-center align-middle">@item.Unit</td>
                                    <td class="text-center align-middle">
                                        <div class="d-flex align-items-center justify-content-center gap-1">
                                            <input type="hidden" value="@item.ProductID" class="hidden-product-id" />
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    onclick="changeQuantity('qty_@item.ProductID', -1)">
                                                <i class="bi bi-dash"></i>
                                            </button>
                                            <input type="number" id="qty_@item.ProductID" name="quantity"
                                                   class="form-control form-control-sm text-center cart-qty-input"
                                                   style="width:55px;"
                                                   value="@item.Quantity" min="1"
                                                   data-product-id="@item.ProductID"
                                                   data-price="@item.SalePrice" />
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    onclick="changeQuantity('qty_@item.ProductID', 1)">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-primary ms-1"
                                                    onclick="updateCartItem(@item.ProductID, 'qty_@item.ProductID', this)"
                                                    title="Cập nhật">
                                                <i class="bi bi-check"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-end align-middle">
                                        @item.SalePrice.ToString("N0") đ
                                    </td>
                                    <td class="text-end align-middle fw-semibold">
                                        @item.TotalPrice.ToString("N0") đ
                                    </td>
                                    @* Thay thế đoạn form xóa cũ bằng nút AJAX *@
                                    <td class="text-center align-middle">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="removeCartItem(@item.ProductID, this)"
                                                title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Nút xóa giỏ & tiếp tục mua -->
                <div class="d-flex justify-content-between mt-3">
                    <form method="post" action="~/Cart/ClearCart">
                        <button type="submit" class="btn btn-outline-danger"
                                onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                            <i class="bi bi-trash me-1"></i>Xóa giỏ hàng
                        </button>
                    </form>
                    <a href="~/Product" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-1"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- Tóm tắt đơn hàng -->
            <div class="col-lg-4">
                <div class="checkout-summary">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Tóm tắt đơn hàng</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Số loại sản phẩm</span>
                        <span>@Model.Count</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tổng số lượng</span>
                        <span>@Model.Sum(x => x.Quantity)</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold">Tổng tiền</span>
                        <span class="checkout-total">@total.ToString("N0") đ</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="~/Cart/Checkout" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-bag-check me-2"></i>Tiến hành đặt hàng
                        </a>
                    }
                    else
                    {
                        <a href="~/Account/Login?returnUrl=/Cart/Checkout" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-person me-2"></i>Đăng nhập để đặt hàng
                        </a>
                        <p class="text-muted small text-center mt-2">
                            Chưa có tài khoản?
                            <a href="~/Account/Register">Đăng ký ngay</a>
                        </p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
         /**
         * Cập nhật số lượng mặt hàng trong giỏ qua AJAX
         * param {number} productID
         * param {string} inputId - ID của input số lượng
         * param {HTMLElement} btn
         */
        function updateCartItem(productID, inputId, btn) {
            const input = document.getElementById(inputId);
            const quantity = parseInt(input?.value) || 1;

            const formData = new FormData();
            formData.append('productID', productID);
            formData.append('quantity', quantity);

            btn.disabled = true;
            fetch('/Cart/UpdateItem', { method: 'POST', body: formData })
                .then(r => {
                    if (!r.ok) throw new Error();
                    // Cập nhật thành tiền dòng này
                    if (input) updateCartRowTotal(input);
                    showToast('Đã cập nhật giỏ hàng', 'success');
                })
                .catch(() => showToast('Không thể cập nhật', 'error'))
                .finally(() => { btn.disabled = false; });
        }

        /**
         * Xóa 1 sản phẩm khỏi giỏ hàng qua AJAX — không reload trang
         * param {number} productID
         * param {HTMLElement} btn - Nút được click (để tìm row cha)
         */
        function removeCartItem(productID, btn) {
            if (!confirm('Xóa sản phẩm này khỏi giỏ hàng?')) return;

            const formData = new FormData();
            formData.append('productID', productID);

            fetch('/Cart/RemoveItem', { method: 'POST', body: formData })
                .then(r => {
                    if (!r.ok) throw new Error('Lỗi server');
                    // Xóa row khỏi bảng
                    const row = btn.closest('tr');
                    if (row) row.remove();
                    // Tính lại tổng
                    recalcCartTotal();
                    // Cập nhật badge
                    updateCartBadge();
                    // Nếu hết hàng thì reload để hiện thông báo giỏ rỗng
                    const rows = document.querySelectorAll('tbody tr');
                    if (rows.length === 0) location.reload();
                })
                .catch(() => showToast('Không thể xóa sản phẩm', 'error'));
        }

        /**
         * Cập nhật số lượng giỏ hàng trên badge header
         */
        function updateCartBadge() {
            fetch('/Cart/GetCartCount')
                .then(r => r.json())
                .then(data => {
                    const badge = document.getElementById('cartBadge');
                    if (badge) badge.textContent = data.count;
                })
                .catch(() => {});
        }
    </script>
}