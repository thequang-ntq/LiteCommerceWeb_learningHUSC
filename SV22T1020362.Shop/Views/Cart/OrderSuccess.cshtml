@model OrderViewInfo
@{
    ViewBag.Title = "Đặt hàng thành công";
    var details = ViewBag.Details as List<OrderDetailViewInfo> ?? new List<OrderDetailViewInfo>();
    decimal total = details.Sum(x => x.TotalPrice);
}

<div class="container py-5">
    <div class="text-center mb-4">
        <div class="mb-3">
            <i class="bi bi-check-circle-fill text-success" style="font-size:4rem;"></i>
        </div>
        <h2 class="fw-bold text-success">Đặt hàng thành công!</h2>
        <p class="text-muted">
            Cảm ơn bạn đã mua hàng. Đơn hàng <strong>#@Model.OrderID</strong>
            của bạn đã được ghi nhận.
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white border rounded p-4 mb-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin đơn hàng</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Mã đơn hàng</dt>
                    <dd class="col-sm-7">#@Model.OrderID</dd>

                    <dt class="col-sm-5">Ngày đặt hàng</dt>
                    <dd class="col-sm-7">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Trạng thái</dt>
                    <dd class="col-sm-7">
                        <span class="badge order-status-new">Đang chờ duyệt</span>
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.DeliveryProvince))
                    {
                        <dt class="col-sm-5">Tỉnh/Thành giao hàng</dt>
                        <dd class="col-sm-7">@Model.DeliveryProvince</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                    {
                        <dt class="col-sm-5">Địa chỉ giao hàng</dt>
                        <dd class="col-sm-7">@Model.DeliveryAddress</dd>
                    }
                </dl>
            </div>

            <!-- Chi tiết sản phẩm -->
            <div class="bg-white border rounded p-4 mb-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Sản phẩm đã đặt</h5>
                @foreach (var item in details)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                        <div>
                            <div class="fw-semibold">@item.ProductName</div>
                            <div class="text-muted small">
                                @item.SalePrice.ToString("N0") đ × @item.Quantity @item.Unit
                            </div>
                        </div>
                        <div class="fw-bold">@item.TotalPrice.ToString("N0") đ</div>
                    </div>
                }
                <div class="d-flex justify-content-between fw-bold fs-5 mt-2">
                    <span>Tổng cộng</span>
                    <span class="text-primary">@total.ToString("N0") đ</span>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a href="~/Order/Detail/@Model.OrderID" class="btn btn-primary">
                    <i class="bi bi-receipt me-1"></i>Xem đơn hàng
                </a>
                <a href="~/" class="btn btn-outline-primary">
                    <i class="bi bi-house me-1"></i>Về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>