@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <nav class="nav flex-column">
                    <a href="~/Account/Profile" class="nav-link">
                        <i class="bi bi-person me-2"></i>Thông tin cá nhân
                    </a>
                    <a href="~/Account/ChangePassword" class="nav-link active">
                        <i class="bi bi-key me-2"></i>Đổi mật khẩu
                    </a>
                    <a href="~/Order" class="nav-link">
                        <i class="bi bi-clock-history me-2"></i>Lịch sử đơn hàng
                    </a>
                    <hr />
                    <a href="~/Account/Logout" class="nav-link text-danger">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </a>
                </nav>
            </div>
        </div>

        <!-- Form đổi mật khẩu -->
        <div class="col-md-9">
            <div class="profile-card">
                <h5 class="fw-bold mb-4 border-bottom pb-2">
                    <i class="bi bi-shield-lock me-2 text-primary"></i>Đổi mật khẩu
                </h5>

                <form method="post" action="~/Account/ChangePassword">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mật khẩu cũ</label>
                            <input type="password" name="oldPassword" class="form-control"
                                   placeholder="Nhập mật khẩu hiện tại" autofocus />
                            <span class="text-danger small">
                                @(ViewData.ModelState["oldPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                            </span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control"
                                   placeholder="Ít nhất 6 ký tự" />
                            <span class="text-danger small">
                                @(ViewData.ModelState["newPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                            </span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                            <input type="password" name="confirmPassword" class="form-control"
                                   placeholder="Nhập lại mật khẩu mới" />
                            <span class="text-danger small">
                                @(ViewData.ModelState["confirmPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                            </span>
                        </div>

                        @Html.ValidationMessage("", new { @class = "text-danger small d-block" })

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-key me-2"></i>Đổi mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>