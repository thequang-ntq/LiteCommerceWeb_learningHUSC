@model Customer
@{
    ViewBag.Title = "Tài khoản của tôi";
}

<div class="container py-4">
    <h2 class="section-title">
        <i class="bi bi-person-circle me-2"></i>Tài khoản của tôi
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    <div class="row g-4">

        <!-- Sidebar menu -->
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <div class="text-center mb-3">
                    <i class="bi bi-person-circle text-primary" style="font-size:3rem;"></i>
                    <div class="fw-bold mt-1">@Model.CustomerName</div>
                    <div class="text-muted small">@Model.Email</div>
                </div>
                <hr />
                <nav class="nav flex-column">
                    <a href="~/Account/Profile"        class="nav-link active">
                        <i class="bi bi-person me-2"></i>Thông tin cá nhân
                    </a>
                    <a href="~/Account/ChangePassword" class="nav-link">
                        <i class="bi bi-key me-2"></i>Đổi mật khẩu
                    </a>
                    <a href="~/Order" class="nav-link">
                        <i class="bi bi-clock-history me-2"></i>Lịch sử đơn hàng
                    </a>
                    <hr />
                    <a href="~/Account/Logout" class="nav-link text-danger">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </a>
                </nav>
            </div>
        </div>

        <!-- Form thông tin -->
        <div class="col-md-9">
            <div class="profile-card">
                <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin cá nhân</h5>

                <form method="post" action="~/Account/Profile">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Họ và tên <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="customerName" class="form-control"
                                   value="@Model.CustomerName" />
                            <span class="text-danger small">
                                @(ViewData.ModelState["customerName"]?.Errors.FirstOrDefault()?.ErrorMessage)
                            </span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tên giao dịch</label>
                            <input type="text" name="contactName" class="form-control"
                                   value="@Model.ContactName" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" class="form-control"
                                   value="@Model.Email" readonly disabled />
                            <small class="text-muted">Email không thể thay đổi</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Điện thoại</label>
                            <input type="tel" name="phone" class="form-control"
                                   value="@Model.Phone" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tỉnh/Thành</label>
                            <select name="province" class="form-select">
                                <option value="">-- Chọn Tỉnh/Thành --</option>
                                @{
                                    var provinces = await DictionaryDataService.ListProvincesAsync();
                                    foreach (var p in provinces)
                                    {
                                        bool selected = Model.Province == p.ProvinceName;
                                        <option value="@p.ProvinceName" selected="@(selected ? "selected" : null)">
                                            @p.ProvinceName
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Địa chỉ</label>
                            <textarea name="address" class="form-control" rows="2">@Model.Address</textarea>
                        </div>
                    </div>

                    @Html.ValidationMessage("", new { @class = "text-danger small d-block mt-2" })

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>