@{
    ViewBag.Title = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập | NTQ Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/shop.css" />
</head>
<body class="bg-light">

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="text-center mb-4">
                    <a href="~/" class="text-decoration-none">
                        <h3 class="fw-bold text-primary">
                            <i class="bi bi-shop me-2"></i>NTQ Shop
                        </h3>
                    </a>
                    <p class="text-muted">Đăng nhập để tiếp tục mua sắm</p>
                </div>

                <div class="bg-white rounded border p-4 shadow-sm">
                    <h5 class="fw-bold mb-4">Đăng nhập</h5>

                    @if (TempData["RegisterSuccess"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle me-2"></i>@TempData["RegisterSuccess"]
                        </div>
                    }

                    <form method="post" action="~/Account/Login">
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" name="username"
                                       class="form-control"
                                       value="@ViewBag.Username"
                                       placeholder="your@email.com"
                                       autofocus />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mật khẩu</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" name="password"
                                       class="form-control"
                                       placeholder="••••••" />
                            </div>
                        </div>

                        @{
                            // Hiển thị lỗi đăng nhập
                            var loginError = ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage
                            ?? ViewData.ModelState["Error"]?.Errors.FirstOrDefault()?.ErrorMessage;
                        }
                        @if (!string.IsNullOrEmpty(loginError))
                        {
                            <div class="alert alert-danger py-2 small">
                                <i class="bi bi-exclamation-circle me-1"></i>@loginError
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100 mt-1">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </form>

                    <hr />
                    <p class="text-center mb-0 small">
                        Chưa có tài khoản?
                        <a href="~/Account/Register" class="fw-semibold">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
</body>
</html>