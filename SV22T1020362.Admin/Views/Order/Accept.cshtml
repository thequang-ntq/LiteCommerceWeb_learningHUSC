@using SV22T1020362.Models.Sales
@model OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-info">
    <strong class="modal-title">
        <i class="bi bi-check-circle me-2"></i>Duyệt chấp nhận đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="alert alert-info d-flex align-items-center">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có chắc chắn muốn duyệt và chấp nhận đơn hàng <strong>#@Model?.OrderID</strong> không?
    </div>
    <dl class="row mb-0">
        <dt class="col-sm-4">Khách hàng</dt>
        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model?.CustomerName) ? "Chưa có" : Model?.CustomerName)</dd>
        <dt class="col-sm-4">Ngày lập đơn</dt>
        <dd class="col-sm-8">@Model?.OrderTime.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
</div>

<div class="modal-footer">
    <form method="post" action="/Order/Accept/@Model?.OrderID">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check me-1"></i>Chấp nhận
        </button>
    </form>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
</div>
