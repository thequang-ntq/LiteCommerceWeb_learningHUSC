@using SV22T1020362.Models.Sales
@model List<OrderDetailViewInfo>
@{
    Layout = null;
    int orderID = ViewBag.OrderID;
    OrderStatusEnum status = ViewBag.OrderStatus;
    decimal totalAmount = Model.Sum(d => d.TotalPrice);
    bool canEdit = (status == OrderStatusEnum.New);
}

<div class="card card-secondary card-outline">
    <div class="card-header">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>Danh sách mặt hàng
                </h5>
            </div>
            @if (canEdit)
            {
                <div class="col text-end">
                    <a href="/Order/AddOrderItem?id=@orderID"
                       class="btn btn-sm btn-primary"
                       onclick="openModal(event, this)">
                        <i class="bi bi-plus-circle me-1"></i>Thêm mặt hàng
                    </a>
                </div>
            }
        </div>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    @if (canEdit)
                    {
                        <th style="width:90px"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];
                    <tr>
                        <td class="text-center">@(i + 1)</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        @if (canEdit)
                        {
                            <td class="text-center text-nowrap">
                                <!-- Nút sửa — gọi openModal trực tiếp -->
                                <a href="/Order/EditOrderItem?id=@orderID&productId=@item.ProductID"
                                   class="btn btn-sm btn-primary"
                                   onclick="openModal(event, this)">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (Model.Count > 1)
                                {
                                    <!-- Nút xóa — gọi openModal trực tiếp -->
                                    <a href="/Order/DeleteOrderItem?id=@orderID&productId=@item.ProductID"
                                       class="btn btn-sm btn-danger"
                                       onclick="openModal(event, this)">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-danger" disabled
                                            title="Đơn hàng phải có ít nhất 1 mặt hàng">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(canEdit ? 7 : 6)" class="text-center text-muted fst-italic">
                            Đơn hàng chưa có mặt hàng nào
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@totalAmount.ToString("N0")</th>
                    @if (canEdit)
                    {
                        <th></th>
                    }
                </tr>
            </tfoot>
        </table>
    </div>
</div>