@using SV22T1020362.Models.Catalog
@model PagedResult<Product>
@{
    Layout = null;
    int orderID = ViewBag.OrderID;
}

@foreach (var item in Model.DataItems)
{
    <form method="post"
          class="border rounded p-2 mb-2"
          onsubmit="addOrderItemFromModal(event, this)">

        <input type="hidden" name="orderID" value="@orderID" />
        <input type="hidden" name="productID" value="@item.ProductID" />

        <strong>@item.ProductName</strong>

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@item.Photo"
                     class="img-fluid border" style="max-height:80px" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input class="form-control form-control-sm"
                               name="salePrice"
                               type="number" step="1000" min="0"
                               value="@((int)item.Price)" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number" name="quantity" min="1" value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>
                <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào đơn
                </button>
            </div>
        </div>
    </form>
}

@if (!Model.DataItems.Any())
{
    <p class="text-muted fst-italic text-center">Không tìm thấy mặt hàng nào</p>
}

<!-- Phân trang — gọi paginateInDetail từ AddOrderItem.cshtml -->
<ul class="pagination pagination-sm justify-content-between mb-0 mt-2">
    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
        <a class="page-link" href="javascript:;" onclick="paginateInDetail(@(Model.Page - 1))">
            <i class="bi bi-chevron-left"></i>
        </a>
    </li>
    <li class="page-item disabled">
        <a class="page-link">Trang @Model.Page / @Model.PageCount</a>
    </li>
    <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
        <a class="page-link" href="javascript:;" onclick="paginateInDetail(@(Model.Page + 1))">
            <i class="bi bi-chevron-right"></i>
        </a>
    </li>
</ul>