@{
    ViewBag.Title = "Trang chủ";

    // Thống kê số liệu thực
    var today = DateTime.Today;

    // Đơn hàng hôm nay
    var todayOrders = await SalesDataService.ListOrdersAsync(new OrderSearchInput
    {
        Page = 1,
        PageSize = 0,
        SearchValue = "",
        DateFrom = today,
        DateTo = today,
        Status = 0
    });

    // Đơn hàng hoàn tất hôm nay → doanh thu
    var completedToday = await SalesDataService.ListOrdersAsync(new OrderSearchInput
    {
        Page = 1,
        PageSize = 0,
        SearchValue = "",
        DateFrom = today,
        DateTo = today,
        Status = OrderStatusEnum.Completed
    });
    decimal todayRevenue = completedToday.DataItems.Sum(o => o.SumOfPrice);

    // Tổng khách hàng
    var customers = await PartnerDataService.ListCustomersAsync(new PaginationSearchInput
    { Page = 1, PageSize = 0, SearchValue = "" });

    // Tổng mặt hàng
    var products = await CatalogDataService.ListProductsAsync(new ProductSearchInput
    { Page = 1, PageSize = 0, SearchValue = "" });

    // Đơn hàng chờ duyệt (New) — hiển thị bảng
    var pendingOrders = await SalesDataService.ListOrdersAsync(new OrderSearchInput
    {
        Page = 1,
        PageSize = 10,
        SearchValue = "",
        DateFrom = null,
        DateTo = null,
        Status = OrderStatusEnum.New
    });

    // Doanh thu 6 tháng gần nhất cho biểu đồ
    var revenueByMonth = new List<decimal>();
    var monthLabels = new List<string>();
    for (int i = 5; i >= 0; i--)
    {
        var month = DateTime.Today.AddMonths(-i);
        var firstDay = new DateTime(month.Year, month.Month, 1);
        var lastDay = firstDay.AddMonths(1).AddDays(-1);
        var monthData = await SalesDataService.ListOrdersAsync(new OrderSearchInput
        {
            Page = 1,
            PageSize = 0,
            SearchValue = "",
            DateFrom = firstDay,
            DateTo = lastDay,
            Status = OrderStatusEnum.Completed
        });
        revenueByMonth.Add(monthData.DataItems.Sum(o => o.SumOfPrice) / 1_000_000m);
        monthLabels.Add($"Tháng {month.Month}/{month.Year}");
    }
}

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@todayRevenue.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">@todayOrders.RowCount</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@customers.RowCount</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@products.RowCount</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="150"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        Laptop Dell
                        <span class="badge bg-success">120</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        iPhone 15
                        <span class="badge bg-success">98</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        Tai nghe Sony
                        <span class="badge bg-success">76</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        Chuột Logitech
                        <span class="badge bg-success">65</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!pendingOrders.DataItems.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted fst-italic py-3">
                                    Không có đơn hàng nào đang chờ duyệt
                                </td>
                            </tr>
                        }
                        @foreach (var item in pendingOrders.DataItems)
                        {
                            <tr>
                                <td>
                                    <a href="~/Order/Detail/@item.OrderID">#@item.OrderID</a>
                                </td>
                                <td>@(string.IsNullOrEmpty(item.CustomerName) ? "Chưa có" : item.CustomerName)</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">@item.SumOfPrice.ToString("N0") đ</td>
                                <td><span class="badge bg-danger">Đang chờ duyệt</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthLabels)),
                datasets: [{
                    label: 'Doanh thu (triệu đồng)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(revenueByMonth)),
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return context.raw.toFixed(1) + ' triệu đồng';
                            }
                        }
                    }
                },
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}