@{
    ViewBag.Title = "Thay đổi mật khẩu";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Đổi mật khẩu
    </button>
    <a href="~/" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-12">
        <form id="formChangePassword" method="post" action="~/Account/ChangePassword">
            <div class="card card-warning card-outline">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-shield-lock me-2"></i>
                        Đổi mật khẩu tài khoản
                    </h5>
                </div>
                <div class="card-body">

                    <!-- Mật khẩu cũ -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu cũ</label>
                        <input type="password" name="oldPassword"
                               class="form-control"
                               placeholder="Nhập mật khẩu cũ" autofocus />
                        <span class="text-danger">
                            @(ViewData.ModelState["oldPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </span>
                    </div>

                    <!-- Mật khẩu mới -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" name="newPassword"
                               class="form-control"
                               placeholder="Nhập mật khẩu mới" />
                        <span class="text-danger">
                            @(ViewData.ModelState["newPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </span>
                    </div>

                    <!-- Xác nhận mật khẩu mới -->
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <input type="password" name="confirmPassword"
                               class="form-control"
                               placeholder="Nhập lại mật khẩu mới" />
                        <span class="text-danger">
                            @(ViewData.ModelState["confirmPassword"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </span>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                </div>
            </div>
        </form>
    </div>
</div>