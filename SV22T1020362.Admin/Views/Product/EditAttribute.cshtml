@model ProductAttribute
@{
    // Lấy danh sách thứ tự đang dùng bởi các thuộc tính khác của cùng sản phẩm
    var existingAttrs = await CatalogDataService.ListAttributesAsync(Model.ProductID);
    // Loại trừ bản thân (khi edit)
    var usedOrders = existingAttrs
        .Where(a => a.AttributeID != Model.AttributeID)
        .Select(a => a.DisplayOrder)
        .OrderBy(x => x)
        .ToList();

    // Gợi ý thứ tự tiếp theo chưa dùng
    int suggestedOrder = Model.AttributeID == 0
        ? (usedOrders.Any() ? usedOrders.Max() + 1 : 1)
        : Model.DisplayOrder;
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>
    <!-- Quay lại trang Edit mặt hàng, cuộn đến phần #attributes -->
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveAttribute">

                    <input type="hidden" asp-for="AttributeID" />
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Tên thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   autofocus />
                            <span asp-validation-for="AttributeName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Giá trị thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g" />
                            <span asp-validation-for="AttributeValue" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" asp-for="DisplayOrder"
                                   class="form-control"
                                   value="@suggestedOrder"
                                   min="1" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                            @if (usedOrders.Any())
                            {
                                <small class="text-muted">
                                    Đã dùng: @string.Join(", ", usedOrders)
                                </small>
                            }
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9 offset-sm-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>